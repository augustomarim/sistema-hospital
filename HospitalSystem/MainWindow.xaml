<Window x:Class="HospitalSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema de Gestão Hospitalar" Height="450" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="🏥 Sistema Hospitalar" 
                       FontSize="22" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,40"/>

            <Button Content="Pacientes" Width="220" Height="45" 
                    Margin="5" Click="btnPacientes_Click"/>

            <Button Content="Funcionários" Width="220" Height="45" 
                    Margin="5" Click="btnFuncionarios_Click"/>

            <Button Content="Consultas" Width="220" Height="45" 
                    Margin="5" Click="btnConsultas_Click"/>

            <Button Content="Departamentos" Width="220" Height="45" 
                    Margin="5" Click="btnDepartamentos_Click"/>

        </StackPanel>
    </Grid>
</Window>
