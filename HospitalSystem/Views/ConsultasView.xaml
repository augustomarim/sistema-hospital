<Window x:Class="HospitalSystem.Views.ConsultasView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Consultas" Height="600" Width="900">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Formulário -->
        <StackPanel Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="Paciente" FontWeight="Bold"/>
                    <ComboBox x:Name="cmbPaciente" Height="30" Margin="0,4,0,0"
                              DisplayMemberPath="Nome"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="Médico" FontWeight="Bold"/>
                    <ComboBox x:Name="cmbMedico" Height="30" Margin="0,4,0,0"
                              DisplayMemberPath="Nome"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="5">
                    <TextBlock Text="Data e Hora" FontWeight="Bold"/>
                    <DatePicker x:Name="dpData" Height="30" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <StackPanel Margin="5">
                <TextBlock Text="Diagnóstico" FontWeight="Bold"/>
                <TextBox x:Name="txtDiagnostico" Height="60" Margin="0,4,0,0"
                         TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>

            <!-- Botões -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Agendar" Width="100" Height="35"
                        Margin="5" Click="btnAgendar_Click"/>
                <Button Content="Excluir" Width="100" Height="35"
                        Margin="5" Click="btnExcluir_Click"/>
                <Button Content="Buscar por Período" Width="140" Height="35"
                        Margin="5" Click="btnBuscarPeriodo_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- Lista -->
        <DataGrid Grid.Row="2" x:Name="dgConsultas"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Paciente" Binding="{Binding Paciente.Nome}" Width="*"/>
                <DataGridTextColumn Header="Médico" Binding="{Binding Medico.Nome}" Width="*"/>
                <DataGridTextColumn Header="Data" Binding="{Binding DataHora}" Width="150"/>
                <DataGridTextColumn Header="Diagnóstico" Binding="{Binding Diagnostico}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
