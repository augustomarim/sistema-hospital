<Window x:Class="HospitalSystem.Views.FichaMedicaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ficha Médica" Height="550" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Dados do paciente -->
        <TextBlock Grid.Row="0" Text="Dados do Paciente" FontWeight="Bold" FontSize="14"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="5">
                <TextBlock Text="Nome" FontWeight="Bold"/>
                <TextBox x:Name="txtNome" Height="30" IsReadOnly="True"
                         Background="#F5F5F5" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="5">
                <TextBlock Text="Tipo Sanguíneo" FontWeight="Bold"/>
                <TextBox x:Name="txtTipoSanguineo" Height="30" IsReadOnly="True"
                         Background="#F5F5F5" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Data criação -->
        <StackPanel Grid.Row="4" Margin="5">
            <TextBlock Text="Data de Criação da Ficha" FontWeight="Bold"/>
            <TextBox x:Name="txtDataCriacao" Height="30" IsReadOnly="True"
                     Background="#F5F5F5" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Alergias -->
        <StackPanel Grid.Row="6" Margin="5">
            <TextBlock Text="Histórico de Alergias" FontWeight="Bold"/>
            <TextBox x:Name="txtAlergias"
                     Height="150"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Botões -->
        <StackPanel Grid.Row="8" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Salvar Ficha" Width="120" Height="35"
                    Margin="5" Click="btnSalvarFicha_Click"/>
            <Button Content="Fechar" Width="100" Height="35"
                    Margin="5" Click="btnFechar_Click"/>
        </StackPanel>
    </Grid>
</Window>