<Window x:Class="HospitalSystem.Views.FuncionariosView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Funcionários" Height="600" Width="900">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Formulário -->
        <StackPanel Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="Nome" FontWeight="Bold"/>
                    <TextBox x:Name="txtNome" Height="30" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="CPF" FontWeight="Bold"/>
                    <TextBox x:Name="txtCPF" Height="30" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="5">
                    <TextBlock Text="CRM/COREN" FontWeight="Bold"/>
                    <TextBox x:Name="txtCRM" Height="30" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="5">
                    <TextBlock Text="Tipo" FontWeight="Bold"/>
                    <ComboBox x:Name="cmbTipo" Height="30" Margin="0,4,0,0"
                              SelectionChanged="cmbTipo_SelectionChanged">
                        <ComboBoxItem>Médico</ComboBoxItem>
                        <ComboBoxItem>Enfermeiro</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- Campo extra Medico/Enfermeiro -->
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="5" x:Name="pnlEspecialidade">
                    <TextBlock Text="Especialidade" FontWeight="Bold"/>
                    <TextBox x:Name="txtEspecialidade" Height="30" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5" x:Name="pnlTurno" Visibility="Collapsed">
                    <TextBlock Text="Turno" FontWeight="Bold"/>
                    <ComboBox x:Name="cmbTurno" Height="30" Margin="0,4,0,0">
                        <ComboBoxItem>Manhã</ComboBoxItem>
                        <ComboBoxItem>Tarde</ComboBoxItem>
                        <ComboBoxItem>Noite</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- Botões -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="btnSalvar" Content="Salvar" Width="100" Height="35"
                        Margin="5" Click="btnSalvar_Click"/>
                <Button x:Name="btnExcluir" Content="Excluir" Width="100" Height="35"
                        Margin="5" Click="btnExcluir_Click"/>
                <Button x:Name="btnLimpar" Content="Limpar" Width="100" Height="35"
                        Margin="5" Click="btnLimpar_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- Lista -->
        <DataGrid Grid.Row="2" x:Name="dgFuncionarios"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*"/>
                <DataGridTextColumn Header="CPF" Binding="{Binding CPF}" Width="130"/>
                <DataGridTextColumn Header="CRM/COREN" Binding="{Binding CRM_COREN}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>